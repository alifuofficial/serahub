generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  password  String     // hashed password
  name      String?
  role      String     @default("USER") // ADMIN or USER
  bookmarks Bookmark[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  jobs      Job[]
  bids      Bid[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Job {
  id          String     @id @default(uuid())
  title       String
  slug        String     @unique
  description String
  source      String?
  applyLink   String?
  deadline    DateTime?
  status      String     @default("PUBLISHED") // DRAFT or PUBLISHED
  views       Int        @default(0)
  categoryId  String?
  category    Category?  @relation(fields: [categoryId], references: [id])
  bookmarks   Bookmark[]
  keywords    String?
  metaDescription String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Bid {
  id          String     @id @default(uuid())
  title       String
  slug        String     @unique
  description String
  source      String?
  applyLink   String?
  deadline    DateTime?
  status      String     @default("PUBLISHED") // DRAFT or PUBLISHED
  views       Int        @default(0)
  categoryId  String?
  category    Category?  @relation(fields: [categoryId], references: [id])
  bookmarks   Bookmark[]
  files       File[]
  keywords    String?
  metaDescription String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Bookmark {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId     String?
  job       Job?     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  bidId     String?
  bid       Bid?     @relation(fields: [bidId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  
  @@unique([userId, jobId])
  @@unique([userId, bidId])
}

model File {
  id        String   @id @default(uuid())
  name      String
  path      String
  size      Int
  bidId     String
  bid       Bid      @relation(fields: [bidId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Subscriber {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model SiteConfig {
  key   String @id
  value String @default("")
}

model PageView {
  id        String   @id @default(uuid())
  path      String
  referrer  String   @default("")
  country   String   @default("")
  createdAt DateTime @default(now())
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  subject   String   @default("")
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Partner {
  id        String   @id @default(uuid())
  name      String
  logoUrl   String
  website   String?
  active    Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
